{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "$ref": "#/definitions/KubeResource",
    "definitions": {
        "KubeResource": {
            "required": [
                "kind",
                "namespace",
                "name",
                "resource_id"
            ],
            "properties": {
                "api_version": {
                    "type": "string",
                    "description": "APIVersion is the API version of the resource (e.g., \"v1\", \"apps/v1\")"
                },
                "kind": {
                    "type": "string",
                    "description": "Kind is the resource kind (e.g., \"Pod\", \"Deployment\")"
                },
                "namespace": {
                    "type": "string",
                    "description": "Namespace is the Kubernetes namespace"
                },
                "name": {
                    "type": "string",
                    "description": "Name is the resource name"
                },
                "resource_id": {
                    "type": "string",
                    "description": "ResourceID is the orchestrator resource ID - used for UID safety check"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Kube Resource",
            "description": "KubeResource represents a Kubernetes resource to act on"
        }
    }
}